# Supabase — get these from your project's Settings → API page
# https://supabase.com/dashboard/project/<your-project>/settings/api

# Server-side (asset-writer, seed script) — keep SECRET, never commit
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Frontend (browser) — safe to expose, anon key only allows public reads
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
